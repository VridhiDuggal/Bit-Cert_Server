generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgStatus {
  active
  revoked
}

model Organisation {
  org_id        String        @id @default(uuid()) @db.Uuid
  msp_id        String        @unique
  org_name      String
  email         String        @unique
  public_key    String
  private_key   String
  password_hash String
  enrolled_at   DateTime      @default(now())
  status        OrgStatus     @default(active)
  logo_url      String?
  website       String?
  description   String?

  certificates      Certificate[]
  recipients        Recipient[]
  inviteTokens      InviteToken[]
  auditLogs         AuditLog[]
  orgRelationships  OrgRecipient[]

  @@index([email])
}

model Recipient {
  recipient_id      String         @id @default(uuid()) @db.Uuid
  email             String         @unique
  name              String
  password_hash     String?
  did               String?
  invited_by_org_id String?        @db.Uuid
  status            String         @default("active")
  notes             String?
  last_login_at     DateTime?
  created_at        DateTime       @default(now())

  organisation     Organisation?   @relation(fields: [invited_by_org_id], references: [org_id])
  certificates     Certificate[]
  notifications    Notification[]
  orgRelationships OrgRecipient[]

  @@index([invited_by_org_id])
}

model OrgRecipient {
  org_id       String   @db.Uuid
  recipient_id String   @db.Uuid
  joined_at    DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [org_id])
  recipient    Recipient    @relation(fields: [recipient_id], references: [recipient_id])

  @@id([org_id, recipient_id])
  @@index([org_id])
  @@index([recipient_id])
}

model InviteToken {
  invite_id        String       @id @default(uuid()) @db.Uuid
  org_id           String       @db.Uuid
  recipient_email  String
  token_hash       String       @unique @db.Char(64)
  expires_at       DateTime
  used_at          DateTime?
  created_at       DateTime     @default(now())

  organisation  Organisation  @relation(fields: [org_id], references: [org_id])

  @@index([org_id])
  @@index([recipient_email])
}

model Certificate {
  certificate_id   String       @id @default(uuid()) @db.Uuid
  org_id           String       @db.Uuid
  recipient_id     String       @db.Uuid
  cert_hash        String       @unique @db.Char(64)
  nonce            String?
  ecdsa_signature  String
  blockchain_tx_id String
  file_path        String
  recipient_name   String
  course           String
  description      String?
  tags             String[]     @default([])
  expiry_date      DateTime?
  template_id      String?
  issue_date       DateTime
  issued_by        String?
  issued_at        DateTime     @default(now())
  is_revoked       Boolean      @default(false)

  organisation      Organisation       @relation(fields: [org_id], references: [org_id])
  recipient         Recipient          @relation(fields: [recipient_id], references: [recipient_id])
  verificationLogs  VerificationLog[]

  @@index([org_id])
  @@index([recipient_id])
  @@index([blockchain_tx_id])
}

model VerificationLog {
  log_id          String       @id @default(uuid()) @db.Uuid
  certificate_id  String       @db.Uuid
  verified_at     DateTime     @default(now())
  verifier_ip     String
  result          Boolean

  certificate  Certificate  @relation(fields: [certificate_id], references: [certificate_id])

  @@index([certificate_id])
  @@index([verified_at])
}

model AuditLog {
  log_id     String   @id @default(uuid()) @db.Uuid
  org_id     String   @db.Uuid
  action     String
  target     String
  metadata   Json?
  created_at DateTime @default(now())

  organisation Organisation @relation(fields: [org_id], references: [org_id])

  @@index([org_id])
  @@index([created_at])
}

model PasswordResetToken {
  token_id   String    @id @default(uuid()) @db.Uuid
  email      String
  user_type  String
  token_hash String    @unique @db.Char(64)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([email])
}

model Notification {
  notification_id  String           @id @default(uuid()) @db.Uuid
  recipient_id     String           @db.Uuid
  recipient        Recipient        @relation(fields: [recipient_id], references: [recipient_id], onDelete: Cascade)
  type             NotificationType
  title            String
  body             String
  cert_hash        String?
  is_read          Boolean          @default(false)
  created_at       DateTime         @default(now())

  @@index([recipient_id])
  @@index([created_at])
}

enum NotificationType {
  CERTIFICATE_ISSUED
  CERTIFICATE_REVOKED
  WELCOME
}
